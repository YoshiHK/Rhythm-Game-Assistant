{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase5FeedbackEvent",
  "description": "Raw feedback event from player or system with no interpretation, for aggregation pipeline",
  "type": "object",

  "required": [
    "event_id",
    "provenance_id",
    "event_type",
    "source_type",
    "timestamp",
    "payload"
  ],

  "properties": {

    "event_id": {
      "type": "string",
      "description": "Unique feedback event identifier"
    },

    "provenance_id": {
      "type": "string",
      "description": "Phase 4 provenance identifier this feedback refers to"
    },

    "event_type": {
      "type": "string",
      "enum": [
        "player_reaction",
        "player_completion",
        "player_dismissal",
        "system_observation"
      ],
      "description": "Category of feedback signal"
    },

    "source_type": {
      "type": "string",
      "enum": [
        "player",
        "system"
      ],
      "description": "Whether feedback comes from player action or system observation"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When feedback was generated"
    },

    "context": {
      "type": "object",
      "description": "Runtime context (no interpretation, only raw linkage to execution)",

      "properties": {
        "player_id": { 
          "type": "string",
          "description": "Player identifier"
        },
        "session_id": { 
          "type": "string",
          "description": "Session identifier"
        },

        "game_id": { 
          "type": "string",
          "description": "Game context"
        },
        "song_id": { 
          "type": "string",
          "description": "Song/content identifier"
        },

        "recommendation_set_id": { 
          "type": "string",
          "description": "Recommendation set identifier"
        },

        "difficulty": { 
          "type": "string",
          "description": "Difficulty level"
        },
        "rank": { 
          "type": "integer",
          "description": "Rank in recommendation set"
        },

        "locale": { 
          "type": "string",
          "description": "Player locale/region"
        },

        "surface": { 
          "type": "string",
          "description": "UI surface/component"
        },
        "mode": { 
          "type": "string",
          "description": "Game mode"
        }
      },

      "additionalProperties": true
    },

    "payload": {
      "type": "object",
      "description": "Raw, uninterpreted feedback payload without semantic processing",

      "properties": {

        "action": {
          "type": "string",
          "description": "Action taken by player (e.g., click, share, play)"
        },

        "reaction_type": {
          "type": "string",
          "description": "Type of reaction (e.g., emoji, thumbs up/down)"
        },

        "completion_status": {
          "type": "string",
          "description": "Completion outcome (e.g., success, failed, quit)"
        },

        "dismiss_reason": {
          "type": "string",
          "description": "Reason given for dismissal"
        },

        "duration_ms": {
          "type": "number",
          "minimum": 0,
          "description": "Duration of interaction in milliseconds"
        },

        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of retries before success or abandonment"
        }
      },

      "additionalProperties": true
    },

    "system_context": {
      "type": "object",
      "description": "System-level signals for non-semantic context (errors, fallbacks, modes)",

      "properties": {
        "selector_used": { 
          "type": "string",
          "description": "Which selector/strategy generated recommendation"
        },
        "fallback_triggered": { 
          "type": "boolean",
          "description": "Whether fallback strategy was activated"
        },
        "degraded_mode": { 
          "type": "boolean",
          "description": "Whether system was in degraded mode"
        },

        "execution_stage": { 
          "type": "string",
          "description": "Pipeline stage during feedback"
        },
        "error_code": { 
          "type": "string",
          "description": "Error code if error occurred"
        }
      },

      "additionalProperties": true
    },

    "experiment": {
      "type": "object",
      "description": "Experiment assignment at time of feedback",
      "required": ["experiment_id"],
      "properties": {
        "experiment_id": { 
          "type": "string",
          "description": "Experiment identifier"
        },
        "variant": { 
          "type": "string",
          "description": "Variant assigned to player"
        }
      },
      "additionalProperties": false
    },

    "ingestion_metadata": {
      "type": "object",
      "description": "Metadata about event ingestion",
      "required": ["platform"],
      "properties": {
        "client_version": { 
          "type": "string",
          "description": "Client application version"
        },
        "platform": { 
          "type": "string",
          "description": "Client platform (iOS, Android, Web)"
        },
        "ingestion_source": { 
          "type": "string",
          "description": "How event was ingested (event queue, webhook, etc.)"
        }
      },
      "additionalProperties": false
    }

  },

  "additionalProperties": false
}
