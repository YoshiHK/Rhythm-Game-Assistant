{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase5FeedbackEvent",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "timestamp",
    "player_id",
    "provenance_id"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "event_type": {
      "type": "string",
      "enum": ["tip_viewed", "tip_used", "tip_ignored", "recommendation_played", "recommendation_skipped"]
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "player_id": { "type": "string" },
    "provenance_id": { "type": "string" },
    "context": {
      "type": "object",
      "additionalProperties": true
    }
  }
}