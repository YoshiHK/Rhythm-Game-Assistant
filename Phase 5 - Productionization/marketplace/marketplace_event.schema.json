{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase5MarketplaceEvent",
  "description": "Event representing marketplace activity (content creation, consumption, transactions)",
  "type": "object",

  "required": [
    "event_id",
    "event_type",
    "timestamp"
  ],

  "properties": {

    "event_id": { 
      "type": "string",
      "description": "Unique event identifier"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When event occurred"
    },

    "event_type": {
      "type": "string",
      "enum": [
        "content_created",
        "content_updated",
        "content_published",
        "content_consumed",
        "content_rated",
        "creator_rewarded",
        "transaction"
      ],
      "description": "Type of marketplace event"
    },

    "provenance_id": {
      "type": "string",
      "description": "Phase 4 provenance identifier for linkage to recommendation execution"
    },

    "player_id": { 
      "type": "string",
      "description": "Player/user involved in event"
    },

    "creator_id": { 
      "type": "string",
      "description": "Creator identifier if applicable"
    },

    "content": {
      "type": "object",
      "description": "Content metadata",
      "properties": {
        "content_id": { 
          "type": "string",
          "description": "Unique content identifier"
        },
        "content_type": { 
          "type": "string",
          "description": "Type of content (song, playlist, etc.)"
        },
        "version": { 
          "type": "string",
          "description": "Content version"
        }
      },
      "additionalProperties": false
    },

    "interaction": {
      "type": "object",
      "description": "User interaction details",
      "properties": {
        "action": { 
          "type": "string",
          "description": "Action taken (play, share, rate, etc.)"
        },
        "rating": { 
          "type": "number",
          "minimum": 0,
          "maximum": 5,
          "description": "Rating given if applicable"
        }
      },
      "additionalProperties": false
    },

    "transaction": {
      "type": "object",
      "description": "Transaction details if event_type is transaction",
      "properties": {
        "amount": { 
          "type": "number",
          "description": "Transaction amount"
        },
        "currency": { 
          "type": "string",
          "description": "Currency code (USD, EUR, etc.)"
        },
        "type": {
          "type": "string",
          "enum": ["purchase", "reward", "refund"],
          "description": "Transaction type"
        }
      },
      "additionalProperties": false
    },

    "metrics": {
      "type": "object",
      "description": "Event metrics and measurements",
      "properties": {
        "engagement_score": { 
          "type": "number",
          "minimum": 0,
          "description": "Calculated engagement score"
        }
      },
      "additionalProperties": true
    },

    "experiment": {
      "type": "object",
      "description": "Experiment assignment if applicable",
      "properties": {
        "experiment_id": { 
          "type": "string",
          "description": "Experiment identifier"
        },
        "variant": { 
          "type": "string",
          "description": "Variant assigned"
        }
      },
      "additionalProperties": false
    }

  },

  "additionalProperties": false
}
