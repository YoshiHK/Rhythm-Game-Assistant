{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase5MarketplaceEvent",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "timestamp",
    "content_id"
  ],
  "properties": {
    "event_id": { "type": "string" },

    "event_type": {
      "type": "string",
      "enum": [
        "content_registered",
        "creator_opt_in",
        "marketplace_view",
        "marketplace_accept"
      ]
    },

    "content_id": { "type": "string" },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "metadata": {
      "type": "object",
      "description": "Non-semantic marketplace context",
      "additionalProperties": true
    }
  }
}