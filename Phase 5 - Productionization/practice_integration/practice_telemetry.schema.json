{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase5PracticeTelemetryEvent",
  "description": "Telemetry event from practice mode capturing user interactions and metrics",
  "type": "object",

  "required": [
    "event_id",
    "event_type",
    "timestamp",
    "provenance_id",
    "practice_context"
  ],

  "properties": {

    "event_id": { 
      "type": "string",
      "description": "Unique event identifier"
    },

    "event_type": {
      "type": "string",
      "enum": [
        "hint_shown",
        "hint_dismissed",
        "practice_retry",
        "section_replayed",
        "session_started",
        "session_ended"
      ],
      "description": "Type of practice event"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When event occurred"
    },

    "provenance_id": {
      "type": "string",
      "description": "Phase 4 provenance identifier linking to recommendation"
    },

    "player_id": {
      "type": "string",
      "description": "Player identifier"
    },

    "session_id": {
      "type": "string",
      "description": "Practice session identifier"
    },

    "practice_context": {
      "type": "object",
      "description": "Practice-specific context",
      "required": ["mode"],
      "properties": {
        "mode": { 
          "type": "string",
          "description": "Practice mode (e.g., single-section, full-song)"
        },
        "game_id": { 
          "type": "string",
          "description": "Game identifier"
        },
        "song_id": { 
          "type": "string",
          "description": "Song/content being practiced"
        },
        "difficulty": { 
          "type": "string",
          "description": "Difficulty level"
        },
        "section_id": { 
          "type": "string",
          "description": "Section being practiced if applicable"
        }
      },
      "additionalProperties": true
    },

    "metrics": {
      "type": "object",
      "description": "Practice metrics",
      "properties": {
        "duration_ms": { 
          "type": "number",
          "minimum": 0,
          "description": "Duration in milliseconds"
        },
        "retry_count": { 
          "type": "integer",
          "minimum": 0,
          "description": "Number of retries"
        }
      },
      "additionalProperties": true
    },

    "experiment": {
      "type": "object",
      "description": "Experiment assignment if applicable",
      "properties": {
        "experiment_id": { 
          "type": "string",
          "description": "Experiment identifier"
        },
        "variant": { 
          "type": "string",
          "description": "Variant assigned"
        }
      },
      "additionalProperties": false
    }
  },

  "additionalProperties": false
}
