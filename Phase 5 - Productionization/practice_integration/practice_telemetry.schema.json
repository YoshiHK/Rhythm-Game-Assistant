{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase5PracticeTelemetryEvent",
  "type": "object",

  "required": [
    "event_id",
    "event_type",
    "timestamp",
    "provenance_id",
    "practice_context"
  ],

  "properties": {

    "event_id": { "type": "string" },

    "event_type": {
      "type": "string",
      "enum": [
        "hint_shown",
        "hint_dismissed",
        "practice_retry",
        "section_replayed",
        "session_started",
        "session_ended"
      ]
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "provenance_id": {
      "type": "string"
    },

    "player_id": {
      "type": "string"
    },

    "session_id": {
      "type": "string"
    },

    "practice_context": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string" },
        "game_id": { "type": "string" },
        "song_id": { "type": "string" },
        "difficulty": { "type": "string" },
        "section_id": { "type": "string" }
      },
      "additionalProperties": true
    },

    "metrics": {
      "type": "object",
      "properties": {
        "duration_ms": { "type": "number" },
        "retry_count": { "type": "integer" }
      },
      "additionalProperties": true
    },

    "experiment": {
      "type": "object",
      "properties": {
        "experiment_id": { "type": "string" },
        "variant": { "type": "string" }
      }
    }
  },

  "additionalProperties": false
}