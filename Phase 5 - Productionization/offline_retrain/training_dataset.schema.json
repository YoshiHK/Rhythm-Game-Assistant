{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase5TrainingDataset",
  "description": "Training dataset containing features and gold labels curated from feedback and curation pipeline",
  "type": "object",

  "required": [
    "dataset_id",
    "created_at",
    "source_range",
    "label_schema_version",
    "samples"
  ],

  "properties": {

    "dataset_id": {
      "type": "string",
      "description": "Unique identifier for this training dataset"
    },

    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this dataset was created"
    },

    "source_range": {
      "type": "object",
      "required": ["from", "to"],
      "description": "Time range of source events included in dataset",
      "properties": {
        "from": { 
          "type": "string", 
          "format": "date-time",
          "description": "Start of time range (inclusive)"
        },
        "to": { 
          "type": "string", 
          "format": "date-time",
          "description": "End of time range (inclusive)"
        }
      },
      "additionalProperties": false
    },

    "label_schema_version": {
      "type": "string",
      "description": "Version of curator_label schema used for curation"
    },

    "feature_schema_version": {
      "type": "string",
      "description": "Version of feature construction logic"
    },

    "aggregation_version": {
      "type": "string",
      "description": "Version of aggregation rules for multi-label samples"
    },

    "samples": {
      "type": "array",
      "description": "Training examples with features and labels",
      "items": {
        "type": "object",

        "required": [
          "provenance_id",
          "features",
          "gold_labels"
        ],

        "properties": {

          "provenance_id": {
            "type": "string",
            "description": "Phase 4 provenance identifier"
          },

          "event_id": {
            "type": "string",
            "description": "Feedback event identifier"
          },

          "curation_id": {
            "type": "string",
            "description": "Curation task identifier"
          },

          "features": {
            "type": "object",
            "description": "Selection-level deterministic features extracted from provenance",

            "required": [
              "game_id",
              "song_id"
            ],

            "properties": {

              "game_id": { 
                "type": "string",
                "description": "Game context identifier" 
              },
              "song_id": { 
                "type": "string",
                "description": "Song/content being recommended"
              },
              "difficulty": { 
                "type": "string",
                "description": "Song difficulty level"
              },
              "rank": { 
                "type": "integer",
                "description": "Recommendation rank in set"
              },
              "action": { 
                "type": "string",
                "description": "User action taken"
              },

              "locale": { 
                "type": "string",
                "description": "Player locale/region"
              },
              "tier_id": { 
                "type": "string",
                "description": "Capability tier identifier"
              },
              "target_metric": { 
                "type": "number",
                "description": "Target optimization metric value"
              },

              "catalog_fingerprint": { 
                "type": "string",
                "description": "Catalog state fingerprint at time of recommendation"
              },
              "recommendation_set_id": { 
                "type": "string",
                "description": "Unique identifier for recommendation set"
              },

              "derived_primary_reason": { 
                "type": "string",
                "description": "Primary reason derived from features"
              },
              "derived_reason_confidence": { 
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Confidence of derived reason"
              }
            },

            "additionalProperties": true
          },

          "gold_labels": {
            "type": "array",
            "description": "Ground truth labels from human curation (may have multiple if aggregated)",

            "items": {
              "type": "object",

              "required": [
                "reason_codes",
                "primary_reason",
                "category",
                "plane"
              ],

              "properties": {

                "primary_reason": {
                  "type": "string",
                  "description": "Primary reason from taxonomy"
                },

                "reason_codes": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "List of applicable reason codes"
                },

                "category": { 
                  "type": "string",
                  "enum": [
                    "EXECUTION",
                    "SELECTION",
                    "PERSONALIZATION",
                    "LOCALIZATION",
                    "API",
                    "CONTROL"
                  ],
                  "description": "High-level category"
                },
                "layer": { 
                  "type": "string",
                  "description": "Logical layer"
                },
                "plane": { 
                  "type": "string",
                  "enum": [
                    "execution",
                    "orchestration",
                    "api_surface",
                    "control"
                  ],
                  "description": "System plane"
                },
                "decision_type": { 
                  "type": "string",
                  "enum": [
                    "primary",
                    "fallback",
                    "override",
                    "normalization"
                  ],
                  "description": "Decision type"
                },
                "cause_type": { 
                  "type": "string",
                  "enum": [
                    "integration",
                    "control",
                    "semantic",
                    "numerical",
                    "environment"
                  ],
                  "description": "Root cause category"
                },
                "signal_type": { 
                  "type": "string",
                  "enum": [
                    "observed_error",
                    "missing_output",
                    "fallback_used",
                    "baseline_gap"
                  ],
                  "description": "Signal type detected"
                }
              },

              "additionalProperties": false
            }
          },

          "model_reason": {
            "type": "object",
            "description": "Model prediction for comparison with gold labels",
            "required": ["reason_codes", "primary_reason"],
            "properties": {
              "reason_codes": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Predicted reason codes"
              },
              "primary_reason": { 
                "type": "string",
                "description": "Predicted primary reason"
              },
              "confidence": { 
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Prediction confidence"
              }
            },
            "additionalProperties": false
          },

          "curator_metadata": {
            "type": "object",
            "description": "Metadata about the curation process",
            "properties": {
              "agreement_type": { 
                "type": "string",
                "enum": ["exact_match", "partial_match", "mismatch"],
                "description": "Agreement with model prediction"
              },
              "is_correct": { 
                "type": "boolean",
                "description": "Whether label is fully correct/high-confidence"
              },
              "severity": { 
                "type": "string",
                "enum": ["low", "medium", "high"],
                "description": "Severity of any issues"
              },
              "notes": { 
                "type": "string",
                "description": "Curator notes"
              },
              "curator_id": { 
                "type": "string",
                "description": "Curator identifier"
              },
              "timestamp": { 
                "type": "string", 
                "format": "date-time",
                "description": "When curation was performed"
              }
            },
            "additionalProperties": false
          }

        },

        "additionalProperties": false
      }
    }
  },

  "additionalProperties": false
}
