{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TelemetryEvent",
  "description": "System telemetry event capturing execution metrics, decisions, and experiment exposure",
  "type": "object",

  "required": [
    "event_id",
    "event_type",
    "timestamp"
  ],

  "properties": {

    "event_id": {
      "type": "string",
      "description": "Unique event identifier"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When event occurred"
    },

    "event_type": {
      "type": "string",
      "enum": [
        "recommendation_served",
        "selection_made",
        "model_inference",
        "pipeline_execution",
        "latency_measurement",
        "error_event",
        "experiment_exposure"
      ],
      "description": "Type of telemetry event"
    },

    "provenance_id": {
      "type": "string",
      "description": "Link to Phase 4 provenance record and feedback pipeline"
    },

    "session_id": {
      "type": "string",
      "description": "User session identifier"
    },

    "player_id": {
      "type": "string",
      "description": "Player/user identifier"
    },

    "context": {
      "type": "object",
      "description": "Runtime context (raw linkage without interpretation)",

      "properties": {
        "game_id": { 
          "type": "string",
          "description": "Game context"
        },
        "song_id": { 
          "type": "string",
          "description": "Song/content identifier"
        },
        "recommendation_set_id": { 
          "type": "string",
          "description": "Recommendation set identifier"
        },
        "rank": { 
          "type": "integer",
          "description": "Recommendation rank"
        },
        "difficulty": { 
          "type": "string",
          "description": "Difficulty level"
        },

        "surface": { 
          "type": "string",
          "description": "UI surface/component"
        },
        "mode": { 
          "type": "string",
          "description": "Game mode"
        },
        "locale": { 
          "type": "string",
          "description": "Player locale"
        }
      },

      "additionalProperties": true
    },

    "metrics": {
      "type": "object",
      "description": "Numeric metrics for aggregation and monitoring",

      "properties": {
        "latency_ms": { 
          "type": "number",
          "minimum": 0,
          "description": "End-to-end latency in milliseconds"
        },
        "execution_time_ms": { 
          "type": "number",
          "minimum": 0,
          "description": "Pipeline execution time in milliseconds"
        },
        "retry_count": { 
          "type": "integer",
          "minimum": 0,
          "description": "Number of retries needed"
        },
        "success": { 
          "type": "boolean",
          "description": "Whether operation succeeded"
        },
        "cost": { 
          "type": "number",
          "minimum": 0,
          "description": "Computational cost/tokens"
        }
      },

      "additionalProperties": true
    },

    "decision": {
      "type": "object",
      "description": "System decisions made (non-semantic, factual)",

      "properties": {
        "selector_used": { 
          "type": "string",
          "description": "Which selector/strategy was used"
        },
        "fallback_triggered": { 
          "type": "boolean",
          "description": "Whether fallback was activated"
        },
        "model_version": { 
          "type": "string",
          "description": "Version of model used"
        },
        "feature_version": { 
          "type": "string",
          "description": "Version of feature pipeline"
        }
      },

      "additionalProperties": true
    },

    "experiment": {
      "type": "object",
      "description": "Experiment assignment if applicable",

      "required": ["experiment_id"],
      "properties": {
        "experiment_id": { 
          "type": "string",
          "description": "Experiment identifier"
        },
        "variant": { 
          "type": "string",
          "description": "Variant assigned"
        },
        "exposed": { 
          "type": "boolean",
          "description": "Whether user was exposed to variant"
        }
      },

      "additionalProperties": false
    },

    "error": {
      "type": "object",
      "description": "Error details if event_type is error_event",

      "properties": {
        "error_code": { 
          "type": "string",
          "description": "Error code/identifier"
        },
        "stage": { 
          "type": "string",
          "description": "Pipeline stage where error occurred"
        },
        "message": { 
          "type": "string",
          "description": "Human-readable error message"
        }
      },

      "additionalProperties": false
    },

    "ingestion_metadata": {
      "type": "object",
      "description": "Metadata about data ingestion",

      "properties": {
        "platform": { 
          "type": "string",
          "description": "Client platform (iOS, Android, Web)"
        },
        "client_version": { 
          "type": "string",
          "description": "Client application version"
        }
      },

      "additionalProperties": false
    }

  },

  "additionalProperties": false
}
