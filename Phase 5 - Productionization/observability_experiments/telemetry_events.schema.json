{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TelemetryEvent",
  "type": "object",

  "required": [
    "event_id",
    "event_type",
    "timestamp"
  ],

  "properties": {

    "event_id": {
      "type": "string"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "event_type": {
      "type": "string",
      "enum": [
        "recommendation_served",
        "selection_made",
        "model_inference",
        "pipeline_execution",
        "latency_measurement",
        "error_event",
        "experiment_exposure"
      ]
    },

    "provenance_id": {
      "type": "string",
      "description": "Link to runtime and feedback pipeline"
    },

    "session_id": {
      "type": "string"
    },

    "player_id": {
      "type": "string"
    },

    "context": {
      "type": "object",

      "properties": {
        "game_id": { "type": "string" },
        "song_id": { "type": "string" },
        "recommendation_set_id": { "type": "string" },
        "rank": { "type": "integer" },
        "difficulty": { "type": "string" },

        "surface": { "type": "string" },
        "mode": { "type": "string" },
        "locale": { "type": "string" }
      },

      "additionalProperties": true
    },

    "metrics": {
      "type": "object",
      "description": "Numeric metrics for aggregation",

      "properties": {
        "latency_ms": { "type": "number" },
        "execution_time_ms": { "type": "number" },
        "retry_count": { "type": "integer" },
        "success": { "type": "boolean" },
        "cost": { "type": "number" }
      },

      "additionalProperties": true
    },

    "decision": {
      "type": "object",
      "description": "System decisions (non-semantic)",

      "properties": {
        "selector_used": { "type": "string" },
        "fallback_triggered": { "type": "boolean" },
        "model_version": { "type": "string" },
        "feature_version": { "type": "string" }
      },

      "additionalProperties": true
    },

    "experiment": {
      "type": "object",

      "properties": {
        "experiment_id": { "type": "string" },
        "variant": { "type": "string" },
        "exposed": { "type": "boolean" }
      },

      "additionalProperties": false
    },

    "error": {
      "type": "object",

      "properties": {
        "error_code": { "type": "string" },
        "stage": { "type": "string" },
        "message": { "type": "string" }
      },

      "additionalProperties": false
    },

    "ingestion_metadata": {
      "type": "object",

      "properties": {
        "platform": { "type": "string" },
        "client_version": { "type": "string" }
      },

      "additionalProperties": false
    }

  },

  "additionalProperties": false
}