{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase5RecommendationResponse",
  "type": "object",

  "required": [
    "response_id",
    "request_id",
    "recommended_items",
    "generated_at"
  ],

  "properties": {

    "response_id": { "type": "string" },

    "request_id": { "type": "string" },

    "provenance_id": { "type": "string" },

    "generated_at": {
      "type": "string",
      "format": "date-time"
    },

    "model_info": {
      "type": "object",
      "properties": {
        "model_version": { "type": "string" },
        "feature_version": { "type": "string" }
      }
    },

    "recommended_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id"],
        "properties": {

          "item_id": { "type": "string" },

          "rank": { "type": "integer" },

          "score": { "type": "number" },

          "reason": {
            "type": "object",
            "properties": {
              "primary_reason": { "type": "string" },
              "reason_codes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },

          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },

    "experiment": {
      "type": "object",
      "properties": {
        "experiment_id": { "type": "string" },
        "variant": { "type": "string" }
      }
    }
  },

  "additionalProperties": false
}