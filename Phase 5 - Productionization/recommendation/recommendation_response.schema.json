{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase5RecommendationResponse",
  "type": "object",
  "required": [
    "response_id",
    "request_id",
    "recommended_items",
    "generated_at"
  ],
  "properties": {
    "response_id": { "type": "string" },
    "request_id": { "type": "string" },

    "recommended_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "rationale"],
        "properties": {
          "item_id": { "type": "string" },

          "rationale": {
            "type": "string",
            "description": "Human-readable explanation"
          }
        }
      }
    },

    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
