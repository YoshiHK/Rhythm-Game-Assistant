{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SongRecommendationResponse",
  "type": "object",
  "required": ["recommendations"],
  "properties": {
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "song_id",
          "game_id",
          "difficulty",
          "related_provenance_ids",
          "recommended_because"
        ],
        "properties": {
          "song_id": { "type": "string" },
          "game_id": { "type": "string" },
          "difficulty": { "type": "string" },
          "related_provenance_ids": { "type": "array", "items": { "type": "string" } },
          "recommended_because": { "type": "array", "items": { "type": "string" } },
          "confidence_level": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    }
  }
}