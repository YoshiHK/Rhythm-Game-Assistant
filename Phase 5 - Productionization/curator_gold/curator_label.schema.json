{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CuratorLabel",

  "type": "object",

  "required": [
    "event_id",
    "provenance_id",
    "curation_id",
    "timestamp",
    "model_reason",
    "curator_reason"
  ],

  "properties": {

    "event_id": {
      "type": "string"
    },

    "provenance_id": {
      "type": "string"
    },

    "curation_id": {
      "type": "string"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "curator_id": {
      "type": "string"
    },

    "model_reason": {
      "type": "object",
      "description": "Output from feedback_interpreter (machine hypothesis)",
      "properties": {
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primary_reason": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        }
      }
    },

    "curator_reason": {
      "type": "object",
      "description": "Human-labeled ground truth aligned with taxonomy",
      "properties": {

        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },

        "primary_reason": {
          "type": "string"
        },

        "category": {
          "type": "string",
          "enum": [
            "EXECUTION",
            "SELECTION",
            "PERSONALIZATION",
            "LOCALIZATION",
            "API",
            "CONTROL"
          ]
        },

        "layer": {
          "type": "string"
        },

        "plane": {
          "type": "string",
          "enum": [
            "execution",
            "orchestration",
            "api_surface",
            "control"
          ]
        },

        "decision_type": {
          "type": "string",
          "enum": [
            "primary",
            "fallback",
            "override",
            "normalization"
          ]
        },

        "cause_type": {
          "type": "string",
          "enum": [
            "integration",
            "control",
            "semantic",
            "numerical",
            "environment"
          ]
        },

        "signal_type": {
          "type": "string",
          "enum": [
            "observed_error",
            "missing_output",
            "fallback_used",
            "baseline_gap"
          ]
        }
      }
    },

    "judgement": {
      "type": "object",
      "description": "Comparison between model and human",
      "properties": {

        "is_correct": {
          "type": "boolean"
        },

        "agreement_type": {
          "type": "string",
          "enum": [
            "exact_match",
            "partial_match",
            "mismatch"
          ]
        },

        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    },

    "notes": {
      "type": "string"
    }

  }
}
