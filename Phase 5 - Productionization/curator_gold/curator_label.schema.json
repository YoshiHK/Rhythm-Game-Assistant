{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CuratorLabel",
  "description": "Ground truth label provided by human curator with comprehensive reasoning taxonomy",
  "type": "object",

  "required": [
    "event_id",
    "provenance_id",
    "curation_id",
    "timestamp",
    "model_reason",
    "curator_reason"
  ],

  "properties": {

    "event_id": {
      "type": "string",
      "description": "Unique identifier for this curation event"
    },

    "provenance_id": {
      "type": "string",
      "description": "Phase 4 provenance identifier linking to runtime execution"
    },

    "curation_id": {
      "type": "string",
      "description": "Unique identifier for this curation task"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When this curation was performed"
    },

    "curator_id": {
      "type": "string",
      "description": "Identifier of human curator who performed labeling"
    },

    "model_reason": {
      "type": "object",
      "description": "Output from feedback_interpreter (machine hypothesis)",
      "required": ["reason_codes", "primary_reason"],
      "properties": {
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of applicable reason codes from model"
        },
        "primary_reason": {
          "type": "string",
          "description": "Single primary reason predicted by model"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Model confidence score"
        }
      },
      "additionalProperties": false
    },

    "curator_reason": {
      "type": "object",
      "description": "Human-labeled ground truth aligned with comprehensive taxonomy",
      "required": ["reason_codes", "primary_reason", "category", "plane"],
      "properties": {

        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of applicable reason codes from taxonomy"
        },

        "primary_reason": {
          "type": "string",
          "description": "Single primary reason from taxonomy"
        },

        "category": {
          "type": "string",
          "enum": [
            "EXECUTION",
            "SELECTION",
            "PERSONALIZATION",
            "LOCALIZATION",
            "API",
            "CONTROL"
          ],
          "description": "High-level recommendation category"
        },

        "layer": {
          "type": "string",
          "description": "Logical layer where decision occurred"
        },

        "plane": {
          "type": "string",
          "enum": [
            "execution",
            "orchestration",
            "api_surface",
            "control"
          ],
          "description": "System plane of decision"
        },

        "decision_type": {
          "type": "string",
          "enum": [
            "primary",
            "fallback",
            "override",
            "normalization"
          ],
          "description": "Type of decision made"
        },

        "cause_type": {
          "type": "string",
          "enum": [
            "integration",
            "control",
            "semantic",
            "numerical",
            "environment"
          ],
          "description": "Root cause category"
        },

        "signal_type": {
          "type": "string",
          "enum": [
            "observed_error",
            "missing_output",
            "fallback_used",
            "baseline_gap"
          ],
          "description": "Type of signal detected"
        }
      },
      "additionalProperties": false
    },

    "judgement": {
      "type": "object",
      "description": "Comparison between model prediction and human label",
      "properties": {

        "is_correct": {
          "type": "boolean",
          "description": "Whether model prediction matches ground truth"
        },

        "agreement_type": {
          "type": "string",
          "enum": [
            "exact_match",
            "partial_match",
            "mismatch"
          ],
          "description": "Level of agreement between model and human"
        },

        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "description": "Severity of any mismatch"
        }
      },
      "additionalProperties": false
    },

    "notes": {
      "type": "string",
      "description": "Optional curator notes for context or clarification"
    }

  },

  "additionalProperties": false
}
