{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase5CuratorGoldLabel",
  "type": "object",
  "required": [
    "label_id",
    "provenance_id",
    "label_type",
    "label_value",
    "curator_id",
    "timestamp",
    "schema_version"
  ],
  "properties": {
    "label_id": { "type": "string" },
    "provenance_id": { "type": "string" },

    "label_type": {
      "type": "string",
      "enum": [
        "tip_effectiveness",
        "severity_accuracy",
        "element_relevance",
        "recommendation_quality"
      ]
    },

    "label_value": {
      "type": ["string", "number", "boolean"]
    },

    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Curator confidence in this label (0–1)"
    },

    "schema_version": {
      "type": "string",
      "description": "Schema version for forward compatibility"
    },

    "curator_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },

    "notes": { "type": "string" }
  }
}
