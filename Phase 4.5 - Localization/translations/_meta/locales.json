{
  "_meta": {
    "description": "Canonical locale configuration and fallback graph",
    "scope": "Phase 4.5 Localization",
    "role": "contract"
  },
  "base_locale": "en-US",
  "supported_locales": [
    "en-US",
    "en-GB",
    "zh-Hans",
    "zh-Hant-HK",
    "zh-Hant-TW",
    "ja-JP",
    "ko-KR",
    "pseudo"
  ],
  "fallbacks": {
    "en-GB": ["en-US"],
    "zh-Hans": ["en-US"],
    "zh-Hant-HK": ["zh-Hant-TW", "en-US"],
    "zh-Hant-TW": ["en-US"],
    "ja-JP": ["en-US"],
    "ko-KR": ["en-US"],
    "pseudo": ["en-US"]
  },
  "constraints": {
    "must_include_base_locale": true,
    "all_locales_must_be_available": true,
    "fallback_chain_must_terminate": true,
    "no_circular_fallbacks": true
  }
}