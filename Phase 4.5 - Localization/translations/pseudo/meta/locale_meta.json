{
  "locale": "pseudo",
  "language": "Pseudo Localization",
  "direction": "LTR",

  "source": "pseudo",

  "role": "testing",
  "ci_only": true,

  "fallback": "en-US",

  "pseudo_rules": {
    "text_expansion_ratio": 1.3,
    "diacritic_injection": true,
    "bracket_wrapping": true,
    "preserve_placeholders": true
  },

  "validation": {
    "require_full_coverage": true,
    "allow_fallback": false,
    "enforce_placeholder_parity": true,
    "enforce_template_parity": true
  },

  "ui_testing": {
    "enable_overflow_detection": true,
    "stress_long_strings": true,
    "stress_special_characters": true
  },

  "notes": "Pseudo locale used exclusively for CI validation, UI stress testing, and structural verification. Not intended for production display."
}