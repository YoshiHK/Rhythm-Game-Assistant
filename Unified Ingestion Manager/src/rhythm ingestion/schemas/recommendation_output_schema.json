{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rhythm-ingestion/schema/recommendation_output.schema.json",
  "title": "RecommendationOutput",
  "description": "Output contract for song recommendations with explanations and gameplay guidance.",
  "type": "object",

  "required": [
    "schema_version",
    "game_id",
    "recommendations"
  ],

  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of the recommendation output contract.",
      "examples": ["v1"]
    },

    "game_id": {
      "type": "string",
      "description": "Target game for which recommendations are generated."
    },

    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "song_id",
          "difficulty_label",
          "rank",
          "confidence",
          "rationale",
          "difficulty_profile"
        ],

        "properties": {
          "song_id": {
            "type": "string",
            "description": "Canonical song identifier."
          },

          "difficulty_label": {
            "type": "string",
            "description": "Difficulty label (e.g. Expert, Master, Append)."
          },

          "rank": {
            "type": "integer",
            "minimum": 1,
            "description": "Rank position in the recommendation list."
          },

          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "System confidence in this recommendation."
          },

          "difficulty_profile": {
            "$ref": "difficulty_profile.schema.json",
            "description": "Difficulty profile used to evaluate suitability."
          },

          "rationale": {
            "type": "object",
            "description": "Explainable reasoning behind the recommendation.",
            "required": [
              "summary",
              "key_factors"
            ],
            "properties": {
              "summary": {
                "type": "string",
                "description": "Human‑readable explanation."
              },

              "key_factors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["factor", "direction"],
                  "properties": {
                    "factor": {
                      "type": "string",
                      "description": "Name of the influencing factor (e.g. density, coordination)."
                    },
                    "direction": {
                      "type": "string",
                      "enum": ["positive", "negative", "neutral"],
                      "description": "How this factor influenced the recommendation."
                    }
                  }
                }
              }
            }
          },

          "tips_preview": {
            "type": "string",
            "description": "Optional short preview of gameplay tips, if available."
          },

          "recommended_actions": {
            "type": "array",
            "description": "Optional actionable suggestions for the player.",
            "items": {
              "type": "string"
            }
          }
        },

        "additionalProperties": false
      }
    },

    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the recommendation was generated."
    }
  },

  "additionalProperties": false
}