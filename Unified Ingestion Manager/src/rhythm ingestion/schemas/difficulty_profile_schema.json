{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rhythm-ingestion/schema/difficulty_profile_schema.json",
  "title": "DifficultyProfile",
  "description": "Compact semantic difficulty profile aggregated from section metrics and pattern tags.",
  "type": "object",

  "required": [
    "difficulty_profile_version",
    "chart_count",
    "section_features_mean",
    "pattern_profile"
  ],

  "properties": {
    "difficulty_profile_version": {
      "type": "string",
      "description": "Version of the difficulty profile contract.",
      "examples": ["v1"]
    },

    "chart_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of charts aggregated into this profile."
    },

    "section_features_mean": {
      "type": "object",
      "description": "Mean chart-level feature vector derived from SectionMetrics.",
      "additionalProperties": {
        "type": "number"
      },
      "examples": [
        {
          "avg_nps": 5.12,
          "peak_nps": 8.4,
          "avg_npb": 2.1,
          "hold_ratio": 0.31,
          "lane_cross_rate": 0.27,
          "spacing_variance": 0.18,
          "bpm_shift_count": 1.6,
          "chart_stop_count": 0.2
        }
      ]
    },

    "pattern_profile": {
      "type": "object",
      "required": [
        "dominant_categories",
        "category_counts",
        "category_shares"
      ],
      "properties": {
        "dominant_categories": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Top semantic pattern categories by frequency.",
          "examples": [["density", "coordination", "readability"]]
        },

        "category_counts": {
          "type": "object",
          "description": "Total counts of detected pattern categories across all charts.",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          },
          "examples": [
            {
              "density": 21,
              "coordination": 14,
              "readability": 9,
              "hold": 6
            }
          ]
        },

        "category_shares": {
          "type": "object",
          "description": "Normalized share (0–1) of each pattern category.",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "examples": [
            {
              "density": 0.42,
              "coordination": 0.28,
              "readability": 0.18,
              "hold": 0.12
            }
          ]
        }
      }
    }
  },

  "additionalProperties": false
}