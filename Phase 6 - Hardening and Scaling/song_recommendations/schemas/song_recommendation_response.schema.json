{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "song_recommendation_response.schema.json",
  "title": "SongRecommendationResponse",
  "type": "object",
  "additionalProperties": true,
  "required": ["mode", "status", "recommendation_set", "persistence", "diagnostics"],
  "properties": {
    "mode": { "type": "string", "const": "songs" },
    "status": { "type": "string" },
    "recommendation_set": { "$ref": "#/$defs/RecommendationSet" },
    "persistence": { "$ref": "#/$defs/PersistencePlan" },
    "diagnostics": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "RecommendationSet": {
      "type": "object",
      "additionalProperties": true,
      "required": ["set_id", "items"],
      "properties": {
        "set_id": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "minItems": 0,
          "items": { "$ref": "#/$defs/RecommendationItem" }
        }
      }
    },
    "RecommendationItem": {
      "type": "object",
      "additionalProperties": true,
      "required": ["recommendation_type", "song_id", "song_name", "difficulty", "level", "rationale"],
      "properties": {
        "recommendation_type": { "type": "string", "enum": ["AP", "FC", "Clear"] },
        "song_id": { "type": "string", "minLength": 1 },
        "song_name": { "type": "string", "minLength": 1 },
        "producer_name": { "type": "string" },
        "difficulty": { "type": "string", "minLength": 1 },
        "level": { "type": "number" },
        "rationale": { "$ref": "#/$defs/Rationale" },
        "is_active": { "type": "boolean" },
        "bookmarked": { "type": "boolean" }
      }
    },
    "Rationale": {
      "type": "object",
      "additionalProperties": true,
      "required": ["summary", "why"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "why": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "related_provenance_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "taxonomy_reasons": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "PersistencePlan": {
      "type": "object",
      "additionalProperties": true,
      "required": ["did_save", "created_count", "delete_ids", "delete_count"],
      "properties": {
        "did_save": { "type": "boolean" },
        "created_count": { "type": "integer", "minimum": 0 },
        "create_records": { "type": "array", "items": { "type": "object" } },
        "delete_ids": { "type": "array", "items": { "type": "string" } },
        "delete_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}