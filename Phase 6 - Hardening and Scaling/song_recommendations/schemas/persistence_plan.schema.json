{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persistence_plan.schema.json",
  "title": "PersistencePlan",
  "type": "object",
  "additionalProperties": true,
  "required": ["did_save", "created_count", "delete_ids", "delete_count"],
  "properties": {
    "did_save": { "type": "boolean" },
    "created_count": { "type": "integer", "minimum": 0 },
    "create_records": { "type": "array", "items": { "type": "object" } },
    "delete_ids": { "type": "array", "items": { "type": "string" } },
    "delete_count": { "type": "integer", "minimum": 0 }
  }
}