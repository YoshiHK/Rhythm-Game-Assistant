{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "game_capability.schema.json",
  "title": "GameCapability",
  "type": "object",
  "additionalProperties": false,
  "required": ["difficulty_tiers", "completion_ladder"],
  "properties": {
    "difficulty_tiers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "completion_ladder": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "tier_aliases": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "completion_aliases": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  }
}