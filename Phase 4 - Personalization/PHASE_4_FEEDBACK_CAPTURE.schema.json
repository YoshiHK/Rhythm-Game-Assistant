{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "PHASE_4_FEEDBACK_CAPTURE.schema.json",
  "title": "Phase 4 Feedback Capture Schema",
  "type": "object",
  "description": "Schema for user feedback capture in Phase 4. Feedback is non-destructive, append-only, and used for triage, QA, and offline training only.",
  "required": [
    "feedback_id",
    "feedback_timestamp",
    "target",
    "signal"
  ],
  "properties": {
    "feedback_id": {
      "type": "string",
      "description": "Unique identifier for this feedback record (UUID or equivalent)."
    },
    "feedback_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when feedback was submitted."
    },
    "target": {
      "type": "object",
      "description": "Reference to the Phase 4 output being evaluated.",
      "required": [
        "request_id",
        "payload_hash"
      ],
      "properties": {
        "request_id": {
          "type": "string"
        },
        "payload_hash": {
          "type": "string",
          "description": "Hash of canonical payload / deterministic baseline."
        },
        "event_id": {
          "type": "string",
          "description": "Optional event log ID associated with this feedback."
        }
      },
      "additionalProperties": false
    },
    "signal": {
      "type": "object",
      "description": "Primary feedback signal from the user.",
      "required": [
        "helpful"
      ],
      "properties": {
        "helpful": {
          "type": "boolean",
          "description": "Whether the user found the tip helpful."
        },
        "flagged": {
          "type": "boolean",
          "description": "Whether the user flagged the tip as problematic."
        }
      },
      "additionalProperties": false
    },
    "reason": {
      "type": "object",
      "description": "Optional structured reason codes when feedback is negative or flagged.",
      "properties": {
        "reason_code": {
          "type": "string",
          "enum": [
            "NOT_HELPFUL",
            "CONFUSING",
            "TOO_GENERIC",
            "TOO_ADVANCED",
            "TOO_BASIC",
            "TONE_ISSUE",
            "IRRELEVANT",
            "INCORRECT",
            "SAFETY_CONCERN"
          ]
        },
        "comment": {
          "type": "string",
          "maxLength": 2000,
          "description": "Optional user comment for triage and QA."
        }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "description": "Non-sensitive context for analysis and aggregation.",
      "properties": {
        "game_id": {
          "type": "string"
        },
        "song_id": {
          "type": [
            "string",
            "integer"
          ]
        },
        "difficulty_label": {
          "type": "string"
        },
        "engine_mode": {
          "type": "string",
          "enum": [
            "deterministic",
            "personalized",
            "debug"
          ]
        },
        "locale": {
          "type": "string"
        },
        "app_version": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "privacy": {
      "type": "object",
      "description": "Privacy and consent metadata.",
      "properties": {
        "player_id_hash": {
          "type": "string",
          "description": "Opaque, hashed player identifier (optional)."
        },
        "consent_version": {
          "type": "string",
          "description": "Consent or TOS version accepted by the user."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}