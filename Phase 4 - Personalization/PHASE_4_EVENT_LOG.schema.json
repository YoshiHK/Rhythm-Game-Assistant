{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "PHASE_4_EVENT_LOG.schema.json",
  "title": "Phase 4 Event Logging Schema",
  "type": "object",
  "description": "Structured event logging record for Phase 4 personalization, UI interactions, and outcomes. Append-only; no PII.",
  "required": [
    "event_id",
    "event_type",
    "event_timestamp",
    "request",
    "context"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Unique event identifier (UUID or equivalent)."
    },
    "event_type": {
      "type": "string",
      "enum": [
        "phase4.request",
        "phase4.decision",
        "phase4.render",
        "phase4.ui_interaction",
        "phase4.feedback",
        "phase4.error"
      ],
      "description": "Event category within Phase 4 lifecycle."
    },
    "event_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when the event occurred."
    },
    "request": {
      "type": "object",
      "description": "Request linkage and hashes (no raw payload stored here).",
      "required": [
        "request_id",
        "payload_hash"
      ],
      "properties": {
        "request_id": {
          "type": "string"
        },
        "payload_hash": {
          "type": "string",
          "description": "Hash of canonical payload / deterministic baseline inputs."
        },
        "session_id": {
          "type": "string"
        },
        "player_id_hash": {
          "type": "string",
          "description": "Opaque, hashed player identifier (optional)."
        },
        "engine_mode": {
          "type": "string",
          "enum": [
            "deterministic",
            "personalized",
            "debug"
          ]
        },
        "locale": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "description": "Non-sensitive context metadata.",
      "required": [
        "game_id"
      ],
      "properties": {
        "game_id": {
          "type": "string"
        },
        "song_id": {
          "type": [
            "string",
            "integer"
          ]
        },
        "difficulty_label": {
          "type": "string"
        },
        "app_version": {
          "type": "string"
        },
        "model_bundle_version": {
          "type": "string"
        },
        "feature_flags": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "boolean",
              "string",
              "number"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "description": "Personalization decision summary (when event_type is phase4.decision/render).",
      "properties": {
        "personalization_allowed": {
          "type": "boolean"
        },
        "gate_fail_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decision_source": {
          "type": "string",
          "enum": [
            "rule",
            "model",
            "hybrid"
          ]
        },
        "model_id": {
          "type": "string"
        },
        "model_version": {
          "type": "string"
        },
        "template_id": {
          "type": "string"
        },
        "variant_id": {
          "type": "string"
        },
        "variant_reason": {
          "type": "string"
        },
        "element_ordering": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ranking_weights": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        }
      },
      "additionalProperties": false
    },
    "ui": {
      "type": "object",
      "description": "UI interaction signals (when event_type is phase4.ui_interaction).",
      "properties": {
        "surface": {
          "type": "string",
          "description": "Screen/module name (e.g. recommendation_history)."
        },
        "action": {
          "type": "string",
          "description": "Interaction verb (view, expand, copy, share, save)."
        },
        "element_id": {
          "type": "string"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "scroll_depth": {
          "type": "number",
          "minimum": 0
        },
        "clicked_why_panel": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "feedback": {
      "type": "object",
      "description": "User feedback payload (when event_type is phase4.feedback).",
      "properties": {
        "helpful": {
          "type": "boolean"
        },
        "flagged": {
          "type": "boolean"
        },
        "reason_code": {
          "type": "string"
        },
        "comment": {
          "type": "string",
          "maxLength": 2000
        }
      },
      "additionalProperties": false
    },
    "outcome": {
      "type": "object",
      "description": "Outcome measures (optional, used for offline analysis).",
      "properties": {
        "tips_generated": {
          "type": "boolean"
        },
        "fallback_used": {
          "type": "boolean"
        },
        "error_code": {
          "type": "string"
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}