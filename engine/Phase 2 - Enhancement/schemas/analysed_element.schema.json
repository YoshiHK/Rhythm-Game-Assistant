{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalysedElement",
  "type": "object",
  "required": ["name", "severity", "score", "section_coverage", "is_chart_defining", "guidance"],
  "properties": {
    "name": { "type": "string" },
    "severity": { "type": "string" },
    "score": { "type": "number", "minimum": 0, "maximum": 1 },
    "section_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
    "is_chart_defining": { "type": "boolean" },
    "guidance": { "$ref": "guidance.schema.json" }
  },
  "additionalProperties": false
}