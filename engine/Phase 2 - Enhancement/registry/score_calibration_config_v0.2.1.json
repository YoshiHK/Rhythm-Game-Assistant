{
  "project": "Project SEKAI Gameplay Tips Generation",
  "artifact": "score_calibration_config",
  "version": "0.1.0",
  "scope": "Phase 2 Track A: scoring + severity calibration",
  "principles": {
    "non_breaking": "Does not change schemas; only changes score/severity assignment internals.",
    "monotonicity": "Scores must be monotonic with severity and with intensity features.",
    "separation": "Adjacent severities should remain separable after calibration.",
    "coverage_independence": "Score represents intensity; section_coverage remains a separate axis."
  },
  "severity_bins": {
    "source": "(5.1) proseka_severity_rules.py SCORE_TO_SEVERITY",
    "strategy": "Keep existing bins as default; allow optional midpoint overrides."
  },
  "severity_midpoints_override": {
  "enabled": true,
  "midpoints": {
    "slight": 0.08,
    "light": 0.22,
    "mild": 0.38,
    "moderate": 0.55,
    "dense": 0.70,
    "complex": 0.84,
    "demanding": 0.95
  }
},
  "coverage": {
    "threshold": "moderate",
    "notes": "coverage(E)=fraction of sections where hook severity >= threshold. Keep default 'moderate' unless tuning for recall."
  },
  "feature_model": {
    "enabled": true,
    "model_type": "piecewise_linear",
    "features": [
      "peak_density_mult",
      "avg_density_mult",
      "density_variance",
      "rest_ratio_inverse",
      "hold_interference_proxy",
      "readability_proxy",
      "temporal_disruption_proxy",
      "bpm_shift_proxy"
    ],
    "weights": {
      "peak_density_mult": 0.18,
      "avg_density_mult": 0.12,
      "density_variance": 0.1,
      "rest_ratio_inverse": 0.1,
      "hold_interference_proxy": 0.12,
      "readability_proxy": 0.12,
      "temporal_disruption_proxy": 0.13,
      "bpm_shift_proxy": 0.13
    },
    "bias": -0.1,
    "blend": 0.3,
    "squash": "sigmoid",
    "post_scale": {
      "min": 0.0,
      "max": 1.0
    }
  },
  "calibration_targets": {
    "preferred": [
      "human_rankings",
      "QA labels per chart",
      "expert review of severity buckets"
    ],
    "weak_supervision": [
      "master_level (if available)",
      "difficulty tier"
    ]
  },
  "evaluation": {
    "metrics": [
      "rank_correlation",
      "bucket_stability",
      "selection_stability",
      "tips_length_compliance"
    ]
  }
}