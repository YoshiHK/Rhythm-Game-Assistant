{
  "schema_id": "analysis_schema.bandori.v1",
  "game_id": "bandori",
  "kind": "analysis_schema",
  "scope": "Phase 3 UMI - analysis assumptions for Bandori",
  "notes": {
    "canonical_kinds": [
      "single",
      "directional",
      "slide",
      "connection"
    ],
    "combo_definition": "beat-aligned hit objects",
    "strict_combo_consistency": false,
    "max_db_note_delta": null
  },
  "sections": {
    "builder": "beat_window_metrics",
    "requires_bpm": true,
    "min_sections_for_analysis": 1
  },
  "severity_model": {
    "track": "A",
    "type": "density_and_pattern_based",
    "supports_section_coverage": true,
    "preserve_severity_labels": true
  },
  "selection": {
    "track": "B",
    "target_count_by_difficulty": {
      "expert": 3,
      "special": 3
    },
    "allow_fallback_sort": true,
    "fallback_sort_key": [
      "score_desc",
      "severity_desc",
      "section_coverage_desc",
      "element_name_asc"
    ]
  },
  "tips": {
    "enabled": true,
    "rationale": "Bandori charts exhibit strong rhythmic regularity, lane constraint clarity, and repeatable gesture patterns, enabling high-quality deterministic tips."
  },
  "artifacts": {
    "training_mapping_default": "tips_training_mapping_bandori.json",
    "analysis_schema_default": null
  },
  "consistency_checks": {
    "table": [
      {
        "check_id": "B1",
        "name": "adapter-validator scope alignment",
        "source_a": "adapter_bandori.py",
        "source_b": "validator_bandori.py",
        "expected": "Both remain structural-only with no gameplay inference",
        "severity": "error"
      },
      {
        "check_id": "B2",
        "name": "tips enablement gate",
        "source_a": "validator_bandori.compute_phase4_gate_state",
        "source_b": "schema.tips.enabled",
        "expected": "Tips enabled only when Phase 4 gate allows",
        "severity": "warning"
      }
    ],
    "notes": "Bandori consistency checks focus on scope and gating rather than raw-type parity, as gameplay semantics are beat-structured and adapter-driven."
  }
}