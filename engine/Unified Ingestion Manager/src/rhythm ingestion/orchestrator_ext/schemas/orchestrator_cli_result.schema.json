{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rhythm-ingestion/schema/orchestrator_cli_result.schema.json",
  "title": "Orchestrator CLI JSON Result",
  "type": "object",
  "required": [
    "file",
    "game_id",
    "passed"
  ],
  "properties": {
    "file": {
      "type": "string",
      "description": "Source file or directory processed."
    },
    "game_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "passed": {
      "type": "boolean",
      "description": "True only if execution completed without STOP."
    },
    "decision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "STOP",
        "DEGRADED"
      ],
      "description": "Final orchestration decision."
    },
    "stage": {
      "type": "string",
      "enum": [
        "INGEST",
        "VALIDATE",
        "APPROACHABILITY",
        "PHASE1",
        "PHASE2",
        "PHASE4"
      ]
    },
    "reason_code": {
      "type": "string",
      "description": "Required when decision is STOP or DEGRADED."
    },
    "run_key": {
      "type": "string"
    },
    "run_report": {
      "$ref": "orchestrator_run_report.schema.json",
      "description": "Optional full structured run report."
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "passed": {
            "const": false
          }
        }
      },
      "then": {
        "required": [
          "decision",
          "stage",
          "reason_code"
        ]
      }
    }
  ],
  "additionalProperties": true
}