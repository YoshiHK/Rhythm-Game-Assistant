{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OrchestratorRunReport",
  "type": "object",
  "required": [
    "run_key",
    "game_id",
    "chart_id",
    "mode",
    "stage_results",
    "degraded_mode"
  ],
  "properties": {
    "run_key": { "type": "string" },
    "game_id": { "type": "string" },
    "chart_id": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["ingest", "tips", "personalized", "full"]
    },
    "stage_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stage", "status"],
        "properties": {
          "stage": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["OK", "STOP", "FAIL", "SKIP"]
          },
          "ms": { "type": ["integer", "null"] },
          "gate": {
            "type": ["object", "null"],
            "properties": {
              "decision": {
                "type": "string",
                "enum": ["ALLOW", "STOP", "DEGRADED"]
              },
              "stage": { "type": "string" },
              "reason_code": { "type": ["string", "null"] },
              "details": { "type": "object" }
            },
            "additionalProperties": true
          },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    },
    "gates": {
      "type": "array",
      "items": { "type": "object" }
    },
    "degraded_mode": { "type": "boolean" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "diagnostics": { "type": "object" }
  },
  "additionalProperties": true
}