{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RGA Tips Meta Report Schema",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "report_type",
    "report_date",
    "report_seq",
    "run_id",
    "total_charts",
    "total_success",
    "total_failed",
    "by_game",
    "metadata_stats",
    "integrity",
    "generated_at"
  ],

  "properties": {
    "report_type": {
      "type": "string",
      "const": "tips_meta"
    },

    "report_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },

    "report_seq": {
      "type": "integer",
      "minimum": 1
    },

    "run_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}_\\d+$"
    },

    "generated_at": {
      "type": "string",
      "format": "date-time"
    },

    "total_charts": {
      "type": "integer",
      "minimum": 0
    },

    "total_success": {
      "type": "integer",
      "minimum": 0
    },

    "total_failed": {
      "type": "integer",
      "minimum": 0
    },

    "by_game": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["success", "failed"],
        "additionalProperties": false,
        "properties": {
          "success": {
            "type": "integer",
            "minimum": 0
          },
          "failed": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },

    "failures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["game_id", "error"],
        "additionalProperties": false,
        "properties": {
          "game_id": {
            "type": "string"
          },
          "song_id": {
            "type": ["string", "null"]
          },
          "song_name": {
            "type": ["string", "null"]
          },
          "difficulty": {
            "type": ["string", "null"]
          },
          "error": {
            "type": "string"
          }
        }
      }
    },

    "metadata_stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "combo_mismatch_charts": {
          "type": "integer",
          "minimum": 0
        },
        "bpm_mismatch_charts": {
          "type": "integer",
          "minimum": 0
        },
        "duration_mismatch_charts": {
          "type": "integer",
          "minimum": 0
        }
      }
    },

    "sections_by_game": {
      "type": "object",
      "additionalProperties": true
    },

    "integrity": {
      "type": "object",
      "required": [
        "hash_algo",
        "schema_version",
        "content_hash_sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "hash_algo": {
          "type": "string",
          "const": "sha256"
        },
        "schema_version": {
          "type": "integer"
        },
        "content_hash_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "prev_content_hash_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "pair_content_hash_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}