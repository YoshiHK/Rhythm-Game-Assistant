{
  "type": "object",

  "required": [
    "report_type",
    "run_id",
    "report_date",
    "generated_at",
    "summary",
    "pipeline_output",
    "integrity"
  ],

  "properties": {
    "report_type": {
      "type": "string",
      "const": "tips_meta"
    },

    "run_id": {
      "type": "string"
    },

    "report_date": {
      "type": "string"
    },

    "generated_at": {
      "type": "string"
    },

    "summary": {
      "type": "object",
      "required": ["total_charts", "success", "failed"],
      "properties": {
        "total_charts": { "type": "integer" },
        "success": { "type": "integer" },
        "failed": { "type": "integer" },
        "success_rate": { "type": "number" }
      }
    },

    "by_game": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "success": { "type": "integer" },
          "failed": { "type": "integer" },
          "success_rate": { "type": "number" }
        }
      }
    },

    "coverage": {
      "type": "object",
      "properties": {
        "charts_with_tips": { "type": "integer" },
        "charts_missing_tips": { "type": "integer" },
        "coverage_rate": { "type": "number" }
      }
    },

    "validation": {
      "type": "object",
      "properties": {
        "inference_failures": { "type": "integer" },
        "empty_pipeline_output": { "type": "integer" },
        "invalid_rows": { "type": "integer" },
        "pipeline_output_error": { "type": "string" }
      },
      "additionalProperties": true
    },

    "pipeline_metrics": {
      "type": "object",
      "properties": {
        "tips_mode": { "type": "string" },
        "total_rows": { "type": "integer" },
        "games_count": { "type": "integer" }
      }
    },

    "difficulty_metrics": {
      "type": "object",
      "properties": {
        "by_difficulty": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        }
      }
    },

    "chart_metrics": {
      "type": "object",
      "properties": {
        "rows_with_bpm": { "type": "integer" },
        "rows_with_duration_ms": { "type": "integer" },
        "rows_with_note_total_chart": { "type": "integer" },

        "missing_name": { "type": "integer" },
        "missing_difficulty": { "type": "integer" },
        "missing_chart_path": { "type": "integer" },
        "missing_bpm": { "type": "integer" },
        "missing_duration_ms": { "type": "integer" },
        "missing_note_total_chart": { "type": "integer" },

        "avg_bpm": { "type": "number" },
        "min_bpm": { "type": "number" },
        "max_bpm": { "type": "number" }
      },
      "additionalProperties": true
    },

    "pipeline_output": {
      "type": "object"
    },

    "integrity": {
      "type": "object",
      "required": ["schema_version"],
      "properties": {
        "schema_version": { "type": "integer" },
        "source_layer": { "type": "string" }
      }
    }
  }
}