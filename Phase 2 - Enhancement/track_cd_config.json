{
  "project": "Project SEKAI Gameplay Tips Generation",
  "artifact": "track_cd_config",
  "version": "0.1.2",
  "scope": "Phase 2 Track C (guidance adaptation) + Track D (narrative polish)",
  "track_c": {
    "dominant_category_strategy": "most_hits",
    "category_priority": [
      "temporal_disruption_tags",
      "readability_tags",
      "slide_complexity_tags",
      "hand_interaction_tags",
      "precision_tags",
      "rhythm_tags",
      "pacing_tags",
      "flow_patterns",
      "vertical_patterns",
      "directional_patterns",
      "alternation_patterns",
      "duration_structure_tags",
      "multi_lane_patterns"
    ],
    "combine_tied_categories": true,
    "max_combined_categories": 2,
    "combine_join_style": "and",
    "cause_variants": {
      "temporal_disruption_tags": {
        "default": "stops or deceptive breaks",
        "expert": "stops or deceptive breaks",
        "master": "stops or deceptive breaks",
        "append": "stops or deceptive breaks"
      },
      "readability_tags": {
        "default": "visibility or recognition difficulty",
        "expert": "visibility or recognition difficulty",
        "master": "visibility or recognition difficulty",
        "append": "visibility or recognition difficulty"
      },
      "flow_patterns": {
        "default": "dense streams or bursts",
        "expert": "dense streams or bursts",
        "master": "dense streams or bursts",
        "append": "dense streams or bursts"
      },
      "precision_tags": {
        "default": "tight spacing or precision requirements",
        "expert": "tight spacing or precision requirements",
        "master": "tight spacing or precision requirements",
        "append": "tight spacing or precision requirements"
      },
      "rhythm_tags": {
        "default": "rhythmic irregularity or syncopation",
        "expert": "rhythmic irregularity or syncopation",
        "master": "rhythmic irregularity or syncopation",
        "append": "rhythmic irregularity or syncopation"
      },
      "slide_complexity_tags": {
        "default": "complex slide or trace structures",
        "expert": "complex slide or trace structures",
        "master": "complex slide or trace structures",
        "append": "complex slide or trace structures"
      }
    },
    "breakdown": {
      "max_example_tags": 2,
      "style": "mixed_cues",
      "include_tied_categories": true,
      "cue_labels": {
        "temporal_disruption_tags": "timing disruption cues",
        "readability_tags": "readability cues",
        "slide_complexity_tags": "slide control cues",
        "hand_interaction_tags": "hand interaction cues",
        "precision_tags": "precision cues",
        "rhythm_tags": "rhythm cues",
        "pacing_tags": "tempo cues",
        "flow_patterns": "density cues",
        "vertical_patterns": "multi-lane cues",
        "directional_patterns": "direction change cues",
        "alternation_patterns": "alternation cues",
        "duration_structure_tags": "endurance cues",
        "multi_lane_patterns": "chord cues"
      }
    },
    "coverage_buckets": {
      "high": 0.6,
      "mid": 0.3
    }
  },
  "track_d": {
    "allow_small_swap": true,
    "swap_scope": "swap_chart_breakdown_and_guidance_only",
    "swap_triggers": {
      "max_words_per_sentence": 30,
      "prefer_guidance_earlier_if_breakdown_long": true,
      "breakdown_word_threshold": 20
    },
    "compression": {
      "paragraph_2_target_sentences": [
        2,
        3
      ],
      "max_total_hard": {
        "expert": 95,
        "master": 105,
        "append": 125
      },
      "trim_order": [
        "drop_secondary_focus_phrase",
        "shorten_mechanical_interaction",
        "shorten_breakdown"
      ]
    }
  }
}
