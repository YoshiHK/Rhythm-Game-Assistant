# -------------------------------------------------
# Python / Backend
# -------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# FastAPI / Uvicorn
*.log
uvicorn.log

# -------------------------------------------------
# Environment variables & secrets (CRITICAL)
# -------------------------------------------------
.env
.env.*
*.env
!.env.example

# API keys / credentials
secrets/
keys/
*.key
*.pem

# -------------------------------------------------
# Generated data (MUST NOT be committed)
# -------------------------------------------------
# Tips / local database outputs
*.xlsx
*.xls
*.csv
*.sqlite
*.db

# Batch summaries / reports
reports/
output/
outputs/
generated/

# Keep canonical contracts / recovery bundle
!tips_meta.schema.json
!MACHINE_SETUP.md
!bootstrap.ps1
!requirements.txt

# -------------------------------------------------
# Chart ingestion inputs (authoritative but local)
# -------------------------------------------------
# Raw chart files live in OneDrive and are ingested offline on PC
Chart File/
charts/
raw_charts/
ingestion_input/

# Tips output meta is machine / run generated by default
Tips Output Meta/

# -------------------------------------------------
# User data (never commit)
# -------------------------------------------------
screenshots/
uploads/
user_data/

# -------------------------------------------------
# OS / Editor noise
# -------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/

# -------------------------------------------------
# Build / deployment artifacts
# -------------------------------------------------
dist/
build/
*.egg-info/

# -------------------------------------------------
# CI runtime outputs (logs and observability artifacts)
# -------------------------------------------------
CI/**/logs/*
CI/**/artifacts/*

# Keep directory structure
!CI/**/logs/.gitkeep
!CI/**/artifacts/.gitkeep

# -------------------------------------------------
# Temporary / scratch
# -------------------------------------------------
tmp/
temp/
scratch/
