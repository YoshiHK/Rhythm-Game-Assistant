{
  "project": "Project SEKAI Chart Analysis Schema (Official Element Version)",
  "version": "2.1.0",

  "elements": {
    "長時間": {},
    "ハネリズム": {},
    "変拍子": {},
    "速度変化": {},
    "譜面停止": {},
    "物量": {},
    "局所難": {},
    "視認難": {},
    "認識難": {},
    "スライド難": {},
    "フリック難": {},
    "トレース難": {},
    "リズム難": {},
    "極小ノーツ": {},
    "トリル": {},
    "乱打": {},
    "階段": {},
    "縦連": {},
    "微縦連": {},
    "くの字": {},
    "左右振り": {},
    "混フレ": {},
    "盆踊り": {},
    "移動2連打": {},
    "持ち替え・交差": {},
    "多点押し": {},
    "5k": {},
    "6k": {},
    "終点判定": {},
    "個人差": {}
  },

  "severity_scale": [
    "slight",
    "light",
    "mild",
    "moderate",
    "dense",
    "complex",
    "demanding"
  ],

  "element_selection_rules": {
    "min_severity": "moderate",
    "score_ratio_threshold": 0.8,
    "target_count": {
      "expert": 3,
      "master": 3,
      "append": 4
    },

    "chart_defining_overrides_enabled": true,

    "chart_defining_elements": [
      "多点押し",
      "fake_end",
      "chart_stop"
    ],

    "hard_constraints": {
      "no_padding": true,
      "assert_exact_count": true,
      "no_severity_downgrade": true
    },

    "sorting_priority": [
      "score_desc",
      "severity_desc",
      "section_coverage_desc"
    ]
  },

  "guidance_catalog": {
    "model": {
      "difficulty_causes": "Primary mechanical reasons the element increases difficulty",
      "chart_breakdown": "Neutral description of how the element manifests in the chart",
      "player_guidance": "Actionable execution focus"
    }
  }
}